# Environment Configuration for Project Phoenix

# ========== ENVIRONMENT ==========
ENVIRONMENT=staging
CI=false
HEADLESS=true

# ========== BASE URLS ==========
BASE_URL=https://the-internet.herokuapp.com
API_BASE_URL=https://the-internet.herokuapp.com
ADMIN_URL=https://admin.the-internet.herokuapp.com

# ========== TIMEOUTS (ms) ==========
DEFAULT_TIMEOUT=5000
NETWORK_TIMEOUT=10000
NAVIGATION_TIMEOUT=30000
ELEMENT_TIMEOUT=5000
ACTION_TIMEOUT=3000

# ========== TEST CREDENTIALS ==========
TEST_USERNAME=tomsmith
TEST_PASSWORD=SuperSecretPassword!
TEST_EMAIL=tomsmith@example.com

# ========== TEST SETTINGS ==========
MAX_RETRIES=2
LOG_LEVEL=info
LOG_CONSOLE=true

# ========== BROWSER SETTINGS ==========
# VIEWPORT_WIDTH=1280
# VIEWPORT_HEIGHT=720

# ========== SCREENSHOT & VIDEO ==========
SCREENSHOT_ON_FAILURE=true
VIDEO_ON_FAILURE=true
TRACE_ON_FAILURE=true
